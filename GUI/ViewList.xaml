<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:vm="clr-namespace:MultiCodes.ViewModels"
                    xmlns:v="clr-namespace:MultiCodes.Views"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataTemplate DataType="{x:Type vm:Sidebar}">
        <v:Sidebar />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:TopBar}">
        <v:TopBar />
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type vm:FileBar}">
        <v:FileBar />
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type vm:CodeEditor}">
        <v:CodeEditor />
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type vm:Console}">
        <v:Console />
    </DataTemplate>
</ResourceDictionary>